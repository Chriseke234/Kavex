# Kavex Production Environment Variables
# Copy this to .env at the root of your project

# SUPABASE CONFIG
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-DO-NOT-EXPOSE # Server-side only

# AI & SEARCH (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=sk-ant-api03-...

# PAYMENT (Flutterwave Escrow)
FLW_PUBLIC_KEY=FLWPUBK_TEST-...
FLW_SECRET_KEY=FLWSECK_TEST-...
FLW_ENCRYPTION_KEY=...

# NOTIFICATIONS (Resend)
RESEND_API_KEY=re_...

# DEPLOYMENT
SITE_URL=https://kavex.com
NODE_ENV=production
